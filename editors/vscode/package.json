{
  "name": "scrutin-runner",
  "displayName": "Scrutin Runner",
  "description": "Fast, watch-mode test runner for R and Python, integrated into VS Code and Positron.",
  "version": "0.0.4",
  "publisher": "VincentArel-Bundock",
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://vincentarelbundock.github.io/scrutin",
  "repository": {
    "type": "git",
    "url": "https://github.com/vincentarelbundock/scrutin"
  },
  "bugs": {
    "url": "https://github.com/vincentarelbundock/scrutin/issues"
  },
  "qna": "marketplace",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#0d9488",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Testing",
    "Linters",
    "Data Science",
    "Other"
  ],
  "keywords": [
    "test",
    "test runner",
    "testing",
    "watch",
    "R",
    "Python",
    "pytest",
    "testthat",
    "tinytest",
    "ruff",
    "linter",
    "data validation",
    "rust"
  ],
  "activationEvents": [
    "workspaceContains:**/.scrutin/config.toml",
    "workspaceContains:**/DESCRIPTION",
    "workspaceContains:**/pyproject.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scrutin.start",
        "title": "Scrutin: Start"
      },
      {
        "command": "scrutin.stop",
        "title": "Scrutin: Stop"
      },
      {
        "command": "scrutin.showPanel",
        "title": "Scrutin: Show Panel"
      },
      {
        "command": "scrutin.restart",
        "title": "Scrutin: Restart"
      },
      {
        "command": "scrutin.init",
        "title": "Scrutin: Init"
      }
    ],
    "configuration": {
      "title": "Scrutin",
      "properties": {
        "scrutin.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the scrutin binary. Leave empty to find it on $PATH."
        },
        "scrutin.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start scrutin when the workspace opens."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^3.0.0",
    "ovsx": "^0.9.0",
    "esbuild": "^0.24.0"
  }
}
